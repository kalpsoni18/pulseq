# Copy this to .env and fill in your values for local development
# DO NOT commit .env to git

PROJECT_ID=your-gcp-project-id
REGION=us-central1

# For local dev only — point to your Firebase service account JSON
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# For local dev — use a local Postgres instance
DATABASE_URL=postgresql+asyncpg://pulseq:password@localhost:5432/pulseqdb

ENVIRONMENT=development
DEBUG=true

KEDA_NAMESPACE=default
CONSUMER_DEPLOYMENT=pulseq-consumer
